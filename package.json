{
  "name": "leveraged",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "author": "dayrain",
  "main": "out/main/index.js",
  "packageManager": "bun@1.2.20",
  "build": {
    "appId": "com.dayrain.leveraged",
    "productName": "Leveraged",
    "copyright": "Copyright @2022 dayrain",
    "asar": true,
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "extraMetadata": {
      "main": "out/main/index.js"
    },
    "mac": {
      "target": [
        "default"
      ],
      "icon": "resources/icon.png"
    },
    "dmg": {
      "title": "Leveraged",
      "icon": "resources/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "resources/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "electron-devtools-installer": "^4.0.0",
    "electron-store": "8.2.0",
    "framer-motion": "^11.15.0",
    "luxon": "^3.5.0",
    "nanoid": "^4.0.2",
    "node-binance-api": "^1.0.22"
  },
  "devDependencies": {
    "@chakra-ui/react": "^2.10.4",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.13.4",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "autoprefixer": "^10.4.21",
    "electron": "^33.3.2",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.3",
    "react": "^18.3.1",
    "react-devtools": "^7.0.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^7.3.1"
  },
  "overrides": {
    "env-paths": "^2.2.1"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:eb": "bun run build && electron-builder",
    "build:eb:mac": "bun run build && electron-builder --mac",
    "build:eb:win32": "bun run build && electron-builder --win nsis:ia32",
    "build:eb:win64": "bun run build && electron-builder --win nsis:x64",
    "build:eb-only:mac": "electron-builder --mac",
    "build:eb-only:win32": "electron-builder --win nsis:ia32",
    "build:eb-only:win64": "electron-builder --win nsis:x64",
    "release": "bun run build && electron-builder --publish=always"
  }
}
